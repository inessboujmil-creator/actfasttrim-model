
[SETTINGS]
# Path to the Tesseract executable.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/macOS example: /usr/bin/tesseract or /usr/local/bin/tesseract
TESSERACT_PATH = C:\Program Files\Tesseract-OCR\tesseract.exe

# The region of the video frame where the timestamp is located.
# Format is a JSON array: [y_start, y_end, x_start, x_end]
TIMESTAMP_ROI = [20, 40, 610, 710]

# The grayscale threshold (0-255) for converting the timestamp to pure black and white.
# This value may need tuning for your specific videos. Higher values are stricter.
OCR_THRESHOLD = 190

# The maximum number of seconds allowed for the OCR time to jump forward in a single interval.
# This helps filter out OCR errors. A value of 300 means any jump over 5 minutes is ignored.
OCR_FLUCTUATION_SECONDS = 300

# The number of past days to scan for new video files upon starting.
# For example, 7 means the script will look for unprocessed videos from the last week.
DAYS_TO_PROCESS = 7

# The number of seconds to wait between scans for new video files.
SCAN_INTERVAL_SECONDS = 300

# A comma-separated list of target times in HH:MM:SS format to find and trim.
TARGET_TIMES = 08:00:00, 14:30:00, 21:00:00

# (Optional) Set to 'true' to save the black-and-white timestamp images for debugging OCR issues.
# The images will be saved in a 'debug_ocr' folder.
DEBUG_OCR = false


[FOLDER_PAIRS]
# This section maps input folders containing raw videos to output folder names.
# The format is: a_unique_key = /path/to/your/video/folder, Desired_Output_Folder_Name
#
# IMPORTANT: The output folder is created as a SIBLING to the input folder.
# Example: If your input is 'E:\Records\CAM1', the output 'CAM1_Trims' will be at 'E:\Records\CAM1_Trims'.

cam1 = E:\MyVideos\FrontDoor, FrontDoor_Trims
cam2 = E:\MyVideos\Backyard, Backyard_Trims

